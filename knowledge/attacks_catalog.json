  "constraints_map": {
    "C1": "Isolation sandbox — cible dans sandbox_cidr, pas production",
    "C2": "Autorisation formelle — authorized_by + authorization_ref obligatoires",
    "C3": "Authentification lanceur — X-Agent-Token valide",
    "C4": "Snapshot — snapshot_id requis avant lancement (hors dry_run)",
    "C5": "Mode simulation Analyseur — via handshake Décideur (SIM_START délégué)",
    "C6": "Information cellules — event C6_CELLULES_NOTIFIEES vers Auditeur",
    "C7": "Santé DC avant lancement — health agents si enforce_health_checks",
    "C8": "Ressources dédiées — VMs sandbox uniquement, plafond CPU/RAM config",
    "C9": "Une simulation à la fois — SIMULATION_ACTIVE",
    "C10": "Fenêtre horaire + durée max par scénario",
    "C11": "Pas de données réelles — interdit cibles production + flag no_real_data",
    "C12": "Plan rollback — rollback_plan_id requis (hors dry_run)",
    "C13": "Journalisation isolée — events Auditeur dédiés simulation_id",
    "C14": "Arrêt auto débordement — global_max_duration + stop Décideur",
    "C15": "Scan santé post-simulation — health check fin de pipeline"
  }
